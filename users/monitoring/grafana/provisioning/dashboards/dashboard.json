{
  "title": "Yovi Services Overview",
  "uid": "yovi-overview",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s) — all services",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"users-service\"}[1m])",
          "legendFormat": "users — {{method}} {{path}} {{status_code}}"
        },
        {
          "expr": "rate(http_requests_total{job=\"gateway-service\"}[1m])",
          "legendFormat": "gateway — {{method}} {{path}} {{status_code}}"
        },
        {
          "expr": "rate(axum_http_requests_total{job=\"gamey-service\"}[1m])",
          "legendFormat": "gamey — {{method}} {{path}} {{status_code}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "P95 Request Duration (s) — all services",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"users-service\"}[5m]))",
          "legendFormat": "users p95"
        },
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"gateway-service\"}[5m]))",
          "legendFormat": "gateway p95"
        },
        {
          "expr": "histogram_quantile(0.95, rate(axum_http_requests_duration_seconds_bucket{job=\"gamey-service\"}[5m]))",
          "legendFormat": "gamey p95"
        }
      ]
    },
    {
      "id": 3,
      "title": "Error Rate (4xx+5xx) — all services",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"users-service\", status_code=~\"4..|5..\"}[1m])",
          "legendFormat": "users errors"
        },
        {
          "expr": "rate(http_requests_total{job=\"gateway-service\", status_code=~\"4..|5..\"}[1m])",
          "legendFormat": "gateway errors"
        },
        {
          "expr": "rate(axum_http_requests_total{job=\"gamey-service\", status_code=~\"4..|5..\"}[1m])",
          "legendFormat": "gamey errors"
        }
      ]
    }
  ]
}